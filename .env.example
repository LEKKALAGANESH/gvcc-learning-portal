# Copy this file to `.env` and fill in real values:  cp .env.example .env

# Database connection. SQLite by default — zero-config, runs anywhere.
# Swap for a Postgres URL in production, e.g.
#   postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public
DATABASE_URL="file:./dev.db"

# JWT signing secret for auth sessions. MUST be a long random string (32+ chars).
# Generate one with:  openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret-32-chars-min"
