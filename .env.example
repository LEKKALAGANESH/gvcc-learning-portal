# Copy this file to `.env` and fill in real values:  cp .env.example .env

# ── Database: Supabase Postgres ──────────────────────────────────────────────
# Get both strings from: Supabase dashboard → Connect → ORMs → Prisma.
#
# DATABASE_URL — Supavisor *transaction* pooler, port 6543. Used by the running app.
#   Serverless opens a connection per invocation; the pooler is what keeps that from
#   exhausting Postgres. `pgbouncer=true` disables prepared statements, which
#   transaction mode does not support.
DATABASE_URL="postgres://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# DIRECT_URL — Supavisor *session* pooler, port 5432. Used only by `prisma db push`,
#   `migrate`, and `seed`, which need a real session. Port 5432 on the pooler host is
#   IPv4-reachable; the raw `db.PROJECT_REF.supabase.co` host is IPv6-only.
DIRECT_URL="postgres://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ── Auth ─────────────────────────────────────────────────────────────────────
# JWT signing secret for auth sessions. MUST be a long random string (32+ chars).
# Generate one with:  openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret-32-chars-min"
