generator client {
  provider = "prisma-client-js"
}

// Supabase Postgres. `url` is the Supavisor transaction pooler (port 6543) — the only mode
// that survives serverless' many short-lived connections. Migrations and `db push` can't run
// through a transaction pooler, so they use `directUrl` (session pooler, port 5432).
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  createdAt    DateTime   @default(now())
  bookmarks    Bookmark[]
  progress     Progress[]
}

model Video {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  description String
  url         String
  thumbnail   String
  durationSec Int
  category    String
  createdAt   DateTime   @default(now())
  bookmarks   Bookmark[]
  progress    Progress[]
}

// Multiple bookmarks per (user, video). label optional; timeSec is the resume point.
model Bookmark {
  id        String   @id @default(cuid())
  label     String?
  timeSec   Float
  userId    String
  videoId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([userId, videoId])
}

// One row per (user, video) — powers continue-watching, progress bar, recently-watched.
model Progress {
  id          String   @id @default(cuid())
  userId      String
  videoId     String
  positionSec Float    @default(0)
  durationSec Float    @default(0)
  completed   Boolean  @default(false)
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video       Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@index([userId, updatedAt])
}
